{
  "name": "coll-fns",
  "version": "1.6.0",
  "type": "module",
  "description": "A functional interface to join MongoDB collections and add hooks before and after insertions, updates and removals.",
  "scripts": {
    "build": "microbundle -f esm,cjs --generateTypes false",
    "dev": "microbundle watch -f esm,cjs --generateTypes false"
  },
  "files": [
    "dist",
    "src/index.d.ts"
  ],
  "repository": "github:davidsavoie1/coll-fns",
  "source": "src/index.js",
  "main": "./dist/coll-fns.cjs",
  "module": "./dist/coll-fns.mjs",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/coll-fns.mjs",
      "require": "./dist/coll-fns.cjs"
    }
  },
  "keywords": [
    "mongodb",
    "meteor",
    "joins",
    "hooks",
    "protocol",
    "find",
    "fetch",
    "query",
    "publish",
    "publication",
    "composite",
    "reactive",
    "denormalization",
    "functional",
    "composable"
  ],
  "author": "David Savoie",
  "license": "ISC",
  "dependencies": {
    "ejson": "^2.2.3",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "microbundle": "^0.15.1",
    "prettier": "^3.8.1"
  }
}
